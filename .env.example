# Copy to .env (gitignored) for local dev. For the hosted HF Space, set the
# same vars at https://huggingface.co/spaces/peaktwilight/momentmarkt-api/settings
# under "Variables and secrets" (encrypted, never visible in the repo).

# ---------------------------------------------------------------------------
# LLM provider for Pydantic AI agents (Opportunity drafts + Surfacing headline
# rewrites). Leave MOMENTMARKT_LLM_PROVIDER empty to keep fixture-only mode —
# the backend falls back to deterministic JSON when no provider is configured.
# ---------------------------------------------------------------------------

# One of: azure | openrouter | (empty)
MOMENTMARKT_LLM_PROVIDER=

# Model name on the chosen provider:
#   azure       → deployment name, e.g. gpt-5.2
#   openrouter  → owner/model, e.g. openai/gpt-4o or anthropic/claude-sonnet-4-6
#   (empty)     → full string form, e.g. openai:gpt-5.2
MOMENTMARKT_LLM_MODEL=

# Azure (only when MOMENTMARKT_LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Semantic novelty downweighting (optional, prod-only)
# ---------------------------------------------------------------------------

# Enables Azure AI Foundry / Azure OpenAI embeddings for Surfacing Agent
# novelty. Leave unset locally; scoring falls back to novelty=1.0.
MOMENTMARKT_SEMANTIC_NOVELTY=

# Prefer a full embeddings endpoint from Azure AI Foundry when available.
# Example: https://.../embeddings
MOMENTMARKT_EMBEDDING_ENDPOINT=
MOMENTMARKT_EMBEDDING_MODEL=
MOMENTMARKT_EMBEDDING_API_KEY=

# If MOMENTMARKT_EMBEDDING_ENDPOINT is unset, the backend can derive an Azure
# OpenAI embeddings URL from AZURE_OPENAI_ENDPOINT + this deployment.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01
MOMENTMARKT_EMBEDDING_TIMEOUT_S=2.5

# OpenRouter (only when MOMENTMARKT_LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Storage (optional)
# ---------------------------------------------------------------------------

# Override the SQLite path. Default is /tmp/momentmarkt-demo.sqlite3
# Set to /data/... if you mount a persistent storage bucket on the HF Space.
# MOMENTMARKT_DB_PATH=/tmp/momentmarkt-demo.sqlite3
